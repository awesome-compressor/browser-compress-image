{
  "name": "@awesome-compressor/browser-compress-image",
  "type": "module",
  "version": "0.0.6",
  "packageManager": "pnpm@10.18.1",
  "description": "Browser image compression library with TypeScript support, multiple output types, and pluggable tool selection.",
  "author": {
    "name": "Simon He",
    "email": "simon.he.dev@gmail.com",
    "url": "https://github.com/Simon-He95"
  },
  "license": "MIT",
  "homepage": "https://github.com/awesome-compressor/browser-compress-image#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/awesome-compressor/browser-compress-image.git"
  },
  "bugs": {
    "url": "https://github.com/awesome-compressor/browser-compress-image/issues"
  },
  "keywords": [
    "image-compression",
    "browser",
    "compress",
    "optimization",
    "typescript",
    "jpeg",
    "png",
    "gif",
    "webp",
    "file-size-reduction",
    "frontend",
    "web-performance",
    "image-optimization",
    "base64",
    "arraybuffer",
    "blob",
    "file-processing",
    "lightweight",
    "modern"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./tools": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./conversion": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./utils": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown --minify",
    "docs:generate": "node ./scripts/generate-status-doc.mjs",
    "docs:check": "node ./scripts/generate-status-doc.mjs --check",
    "package:check": "node ./scripts/check-package-contract.mjs",
    "play": "pnpm run -C playground dev",
    "dev": "pnpm run -C playground dev",
    "play:build": "pnpm run -C playground build",
    "lint": "git ls-files -z | xargs -0 prettier --write --ignore-unknown",
    "test": "vitest --dir test -u",
    "test:ci": "vitest --dir test -u",
    "ptest": "pnpm run -C playground test -u",
    "preview": "pnpm run -C playground preview",
    "test:e2e": "cypress open",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build",
    "release": "bumpp --commit --tag --push && git push origin --tags -f && npm publish"
  },
  "dependencies": {
    "browser-image-compression": "^2.0.2",
    "compressorjs": "^1.2.1",
    "gifsicle-wasm-browser": "^1.5.16"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.19.0",
    "@sxzz/prettier-config": "^2.2.4",
    "@types/node": "^17.0.45",
    "bumpp": "^7.2.0",
    "eslint": "^9.37.0",
    "prettier": "^3.6.2",
    "tsdown": "^0.12.9",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "yaml": "^2.8.1"
  },
  "prettier": "@sxzz/prettier-config"
}
